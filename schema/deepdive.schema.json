{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DeepDive",
  "type": "object",
  "required": ["opportunityId", "createdAt"],
  "properties": {
    "opportunityId": { "type": "string" },
    "competitors": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "url": { "type": "string" },
          "whatTheyDo": { "type": "string" },
          "weakness": { "type": "string" }
        }
      }
    },
    "userQuotes": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "source": { "type": "string" },
          "url": { "type": "string" },
          "quote": { "type": "string" }
        }
      }
    },
    "marketSignals": { "type": "array", "items": { "type": "string" } },
    "monetizationGuess": { "type": "string" },
    "riskAssessment": { "type": "string" },
    "speedToTest": { "type": "string" },
    "suggestedActions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "enum": ["validation", "research", "build", "outreach"] },
          "description": { "type": "string" },
          "timeEstimate": { "type": "string" },
          "requiresApproval": { "type": "boolean", "default": true }
        }
      }
    },
    "assignedTo": { "type": "string", "default": "jarvis" },
    "createdAt": { "type": "string", "format": "date-time" }
  }
}
