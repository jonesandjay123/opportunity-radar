{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Opportunity",
  "type": "object",
  "required": ["id", "title", "problem", "status", "createdAt"],
  "properties": {
    "id": { "type": "string", "description": "Unique ID (e.g., opp_20260318_001)" },

    "title": { "type": "string", "description": "One-line opportunity title (English)" },
    "title_zh": { "type": "string", "description": "中文標題" },

    "problem": { "type": "string", "description": "What's the pain point? (English)" },
    "problem_zh": { "type": "string", "description": "痛點描述（中文）" },

    "who": { "type": "string", "description": "Who has this problem?" },

    "currentSolution": { "type": "string", "description": "How do people solve it now?" },

    "whyItSucks": { "type": "string", "description": "Why the current solution is bad (English)" },
    "whyItSucks_zh": { "type": "string", "description": "現有方案為何爛（中文）" },

    "opportunityAngle": { "type": "string", "description": "How Jones could approach this (English)" },
    "opportunityAngle_zh": { "type": "string", "description": "切入角度（中文）" },

    "evidence": {
      "type": "array",
      "description": "Real source URLs + quotes (keep in original language)",
      "items": {
        "type": "object",
        "properties": {
          "source": { "type": "string" },
          "url": { "type": "string" },
          "quote": { "type": "string" }
        }
      }
    },

    "scores": {
      "type": "object",
      "properties": {
        "painIntensity": { "type": "number", "minimum": 1, "maximum": 5 },
        "frequency": { "type": "number", "minimum": 1, "maximum": 5 },
        "willingnessToPay": { "type": "number", "minimum": 1, "maximum": 5 },
        "automationPotential": { "type": "number", "minimum": 1, "maximum": 5 },
        "jonesFit": { "type": "number", "minimum": 1, "maximum": 5 },
        "competitionGap": { "type": "number", "minimum": 1, "maximum": 5 },
        "crossBorderArbitrage": { "type": "number", "minimum": 1, "maximum": 5 },
        "scrappiness": { "type": "number", "minimum": 1, "maximum": 5, "description": "5=今天就能測, 1=要半年開發" },
        "total": { "type": "number" }
      }
    },

    "firstTest": {
      "type": "object",
      "description": "今天就能做的最小驗證行動",
      "properties": {
        "type": { "type": "string", "enum": ["reddit_post", "landing_page", "dm", "manual_service", "survey", "competitor_test", "content_test"] },
        "description": { "type": "string", "description": "English description" },
        "description_zh": { "type": "string", "description": "中文描述" },
        "timeEstimate": { "type": "string" }
      }
    },

    "signalStrength": {
      "type": "object",
      "properties": {
        "numMentions": { "type": "number" },
        "recency": { "type": "string", "enum": ["high", "medium", "low"] },
        "trend": { "type": "string", "enum": ["increasing", "stable", "decreasing"] }
      }
    },

    "sourceMeta": {
      "type": "object",
      "description": "訊號來源的地區/語言/平台（預留多語言擴充）",
      "properties": {
        "region": { "type": "string", "description": "e.g., US, TW, JP, KR" },
        "language": { "type": "string", "description": "e.g., en, zh, ja" },
        "platform": { "type": "string", "description": "e.g., reddit, ptt, hn, 5ch" }
      }
    },

    "recommendedFocus": { "type": "boolean", "default": false, "description": "今日推薦（每天最多標 1 個）" },

    "tags": { "type": "array", "items": { "type": "string" } },
    "category": {
      "type": "string",
      "enum": ["human-needs", "life-friction", "cross-border", "tech-gap", "service", "content", "other"]
    },
    "signals": {
      "type": "object",
      "properties": {
        "workaroundDetected": { "type": "boolean" },
        "payingButAngry": { "type": "boolean" },
        "jonesLeverage": { "type": "boolean" }
      }
    },
    "status": {
      "type": "string",
      "enum": ["new", "starred", "selected", "researching", "actionable", "archived", "rejected"]
    },
    "stage": {
      "type": "string",
      "enum": ["signal", "opportunity", "deep-dive", "validation", "action"]
    },
    "jonesNotes": { "type": "string", "description": "Jones's personal comments" },
    "jonesRating": { "type": "number", "minimum": 0, "maximum": 5, "description": "Jones's gut feeling (stars)" },
    "assignedTo": { "type": "string", "default": "jarvis", "description": "Which agent is responsible" },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" },
    "sourceDate": { "type": "string", "format": "date", "description": "Which daily scan produced this" }
  }
}
